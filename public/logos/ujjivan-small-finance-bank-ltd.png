ight\":666,\"formats\":{\"thumbnail\":{\"url\":\"/assets/thumbnail_RBI_responsive_22d28e38da.webp\"}},\"size\":64.79,\"url\":\"/assets/RBI_responsive_22d28e38da.webp\"},\"link\":null,\"button\":null,\"video\":null,\"banner_heading\":null}],\"title\":null,\"description\":null,\"decorative_image\":null,\"static_mobile_image\":null,\"silder_setting\":{\"id\":75282,\"autoplay\":true,\"show_arrows\":true,\"show_dots\":true,\"autoplay_duration\":5,\"Loop\":true},\"button\":{\"id\":43254,\"label\":null,\"variant\":null,\"open_in_new_tab\":null,\"size\":null,\"type\":null,\"button_allign\":null,\"url\":null},\"sub_title\":null,\"static_image\":null,\"section_anchor_id\":null,\"strapiData\":{\"id\":11077,\"__component\":\"banner.banner\",\"carousel_slides\":\"$28:props:carousel_slides\",\"title\":null,\"description\":null,\"decorative_image\":null,\"static_mobile_image\":null,\"silder_setting\":\"$28:props:silder_setting\",\"button\":\"$28:props:button\",\"sub_title\":null,\"static_image\":null,\"section_anchor_id\":null}}]\n"])</script><script nonce="p307sFQbPuuSl6KZbdTf9w==">self.__next_f.push([1,"29:[\"$\",\"$L35\",\"custom.announcement-bar-2322\",{\"date\":\"$undefined\",\"faq_category\":null,\"language_selector\":\"$undefined\",\"select_language\":\"$undefined\",\"id\":2322,\"announcement_label\":\" Latest News :\",\"announcement\":[{\"id\":14504,\"announcement_title\":\"The Interest credit frequency for Savings Accounts will be revised from quarterly to monthly w.e.f. 1st July 2026.\"},{\"id\":14505,\"announcement_title\":\"Dear Customer, SMS alert charges will be revised to ₹0.30 per SMS w.e.f. 01/08/2026. Maximum Monthly charges revised from ₹5 to ₹10. Ujjivan SFB.\"},{\"id\":14506,\"announcement_title\":\"1. Dear Customer, Effective from 1st May 2026, cash withdrawal transactions made through UPI-ICCW shall be considered in the monthly free limits along with transaction initiated with Debit card. The transactions over and above the monthly free limits shall be chargeable.  if you are experiencing any issues in receiving OTPs, kindly check the Spam/Blocked folder in your message inbox and mark UJJIVN-S messages as ‘Not Spam’ to ensure seamless banking experience. For queries, please call us at 1800 208 2121.  Ujjivan SFB.\"},{\"id\":14507,\"announcement_title\":\"2. Dear Customer, Form 15G/H has been unified into Form 121 effective 01-04-2026. The Form 15G/H option will no longer be available on IB \u0026 MB. Kindly visit your nearest branch to submit Form 121. Ujjivan SFB.\"},{\"id\":14508,\"announcement_title\":\"3. Dear Customer, effective 15-Oct-2025, complimentary airport lounge access on your USFB RuPay Platinum \u0026 Domestic Select Debit Card will require minimum spends of ₹5,000 in the previous quarter (Jul–Sep 2025). Only POS and e-commerce transactions done on the debit card will be considered to avail 1 complimentary domestic lounge visit per quarter. Call@18002082121 for info. Ujjivan SFB.\"},{\"id\":14509,\"announcement_title\":\" 4. Savings Deposit rates revised w.e.f. 05-06-2026. The highest rate offered by Ujjivan SFB stands at 7.15% p.a. Visit our website for details. T\u0026C apply.\"},{\"id\":14510,\"announcement_title\":\"5. Dear Customer, This is to inform you that, effective from 9th May’25, Financial ATM/Micro ATM transactions beyond free limits shall be charged Rs.23+GST per transaction. The free transaction limits remain the same as per your Account variant – Ujjivan SFB.\"},{\"id\":14511,\"announcement_title\":\"6. Important Update! New Android Version of Ujjivan Mobile Banking App is available. Download the latest version of Mobile Banking Application from Play Store. If any queries contact 1-800-208-2121 for support. Ujjivan SFB.\"},{\"id\":14512,\"announcement_title\":\"7. Boost your savings with our Tax Saver Deposits, offering attractive interest rates and tax advantages under Section 80C of Income Tax.\"},{\"id\":14513,\"announcement_title\":\"8. Dear Customer, Do not download any application (.apk file) or click on any links received from any unknown sources. Do not share your personal information or financial credentials such as PAN, Aadhaar, A/C No., ATM card details, OTP, etc. via SMS, Whatsapp, E-mail or any other mode of electronic/digital communication. Ujjivan SFB never asks you to download any app or seeks your personal information through WhatsApp messages, SMS or calls. Stay Alert. Ujjivan SFB.\"},{\"id\":14514,\"announcement_title\":\"9. Dear Customer, Issuance Fee \u0026 Annual Maintenance charge for Debit Card have been revised with effect from July 01, 2024, as informed earlier. Also, charges are applicable for cash withdrawal from Micro ATMs over permissible limits. Please visit our website or nearest branch to know more. Ujjivan SFB.\"},{\"id\":14515,\"announcement_title\":\"10. Monthly Average Balance of 1,000 needs to be maintained in the regular savings bank account to avoid charges. For regular savings bank accounts opened till 15th January 2024, the MAB requirements will be applicable from 01st April 2024.\"}],\"announcement_timer\":120,\"strapiData\":{\"id\":2322,\"__component\":\"custom.announcement-bar\",\"announcement_label\":\" Latest News :\",\"announcement\":\"$29:props:announcement\",\"announcement_timer\":120}}]\n"])</script><script nonce="p307sFQbPuuSl6KZbdTf9w==">self.__next_f.push([1,"2a:[\"$\",\"$L36\",\"card.features-card-2450\",{\"date\":\"$undefined\",\"faq_category\":null,\"language_selector\":\"$undefined\",\"select_language\":\"$undefined\",\"id\":2450,\"Product_Card\":[{\"id\":38957,\"sub_title\":\"More Delight on your savings\",\"description\":null,\"arrow_icon\":[{\"id\":194,\"name\":\"right-arrow (1).png\",\"alternativeText\":\"right arrow\",\"caption\":null,\"width\":128,\"height\":128,\"formats\":null,\"size\":0.31,\"url\":\"/assets/right_arrow_1_7935eff5f1.png\"}],\"button\":null,\"decorative_image\":[{\"id\":230,\"name\":\"leaf-hover.png\",\"alternativeText\":\"leaf hover\",\"caption\":null,\"width\":158,\"